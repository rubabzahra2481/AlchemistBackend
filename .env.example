# AI Alchemist Environment Variables
# Copy this file to .env and add your actual API keys

# ============================================
# REQUIRED - At least one LLM provider needed
# ============================================

# OpenAI (Recommended - Required for GPT-4o, GPT-4-Turbo, GPT-3.5-Turbo)
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# OPTIONAL - Only if using these LLM providers
# ============================================

# Anthropic Claude (Optional - For Claude 3.5 Sonnet, Claude 3 Opus, Claude 3 Haiku)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek (Optional - For DeepSeek Chat)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Gemini (Optional - For Gemini 1.5 Pro, Gemini 1.5 Flash)
GOOGLE_API_KEY=your_google_api_key_here

# ============================================
# SERVER CONFIGURATION
# ============================================

# Backend server port (default: 5000)
PORT=5000

# Node environment (development/production)
NODE_ENV=development

# ============================================
# TOP-UP (for Munawar's backend server-to-server)
# ============================================

# Shared secret for POST /credits/top-up (Munawar's backend sends this in x-topup-secret header)
# Generate a long random string; both agent backend and Munawar backend must use the same value.
TOPUP_SECRET=your_long_random_secret_here

# ============================================
# COMPLIANCE & E-SIGN (Amiqus + DocuSeal) — optional
# ============================================

# Amiqus ID API (Bearer token for https://id.amiqus.co/api/v2)
AMIQUS_API_KEY=

# Optional: override DBS step type if not using default check.criminal (Amiqus API step type string)
# AMIQUS_DBS_STEP_TYPE=check.criminal

# DocuSeal (self-hosted or cloud). POST submissions to {DOCUSEAL_URL}/api/submissions
DOCUSEAL_API_KEY=
DOCUSEAL_URL=https://api.docuseal.com

# Template IDs (integers) for contract type routing
HSPSLA_TEMPLATE_ID=
TENANTS_TEMPLATE_ID=

# Munawar internal backend (for compliance status/link sync)
PARTNER_BACKEND_URL=
